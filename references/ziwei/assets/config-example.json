    "convert_calendar",
    "build_palaces",
    "place_major_stars",
    "place_aux_stars",
    "apply_four_transformations",
    "build_grand_limit_and_annual_flow",
    "interpret_by_palace_and_theme",
    "render_structured_output"
  ],
  "output_template": {
    "命宫": {},
    "事业宫": {},
    "财帛宫": {},
    "婚姻": {},
