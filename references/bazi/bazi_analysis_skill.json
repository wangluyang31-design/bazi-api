    "structure",
    "shensha",
    "dayun",
    "liunian"
  ],
  "rules": {
    "four_pillars": {
      "year_pillar": {
        "rule": "birth_datetime >= 当年立春瞬时 -> gz_year = 公历年，否则 gz_year = 公历年 - 1",
        "formula": {
          "year_stem_index": "((gz_year - 4) mod 10) + 1",
          "year_branch_index": "((gz_year - 4) mod 12) + 1"
        }
      },
      "month_pillar": {
        "rule": "按 12 节切月；寅月从立春开始，卯月从惊蛰开始，依次类推",
        "formula": {
          "month_order": "由当前太阳黄经所在节令区间确定，寅=1 ... 丑=12",
          "yin_month_start_stem_index": "((2 * year_stem_index) mod 10) + 1",
          "month_stem_index": "((yin_month_start_stem_index + month_order - 2) mod 10) + 1"
        }
      },
      "day_pillar": {
        "rule": "23:00 子初换日",
        "formula": {
          "jdn": "Gregorian JDN",
          "day_stem_index": "((JDN - 1) mod 10) + 1",
          "day_branch_index": "((JDN + 1) mod 12) + 1"
        }
      },
      "hour_pillar": {
        "rule": "时支按每 2 小时一个时辰，时干按五鼠遁",
        "formula": {
          "hour_branch_index": "floor(((hour + 1) mod 24) / 2) + 1",
          "zi_hour_start_stem_index": "(((day_stem_index - 1) mod 5) * 2) + 1",
          "hour_stem_index": "((zi_hour_start_stem_index + hour_branch_index - 2) mod 10) + 1"
        }
      }
    },
    "five_elements_scoring": {
      "visible_stems": "年干、月干、日干、时干各计 1.0",
      "hidden_stems": "地支藏干按 1/2/3 藏干分别加权 [1.0] / [0.7,0.3] / [0.7,0.2,0.1]",
      "status_thresholds": {
        "偏缺": "score < 1.0",
        "偏弱": "1.0 <= score < 1.5",
        "平衡": "1.5 <= score < 2.5",
        "偏旺": "2.5 <= score < 3.0",
        "过旺": "score >= 3.0"
      }
    },
    "ten_gods": {
      "core_rule": "以日主为中心，先定五行关系，再看阴阳同异",
      "mapping": {
        "same": {
          "same_polarity": "比肩",
          "different_polarity": "劫财"
        },
        "output": {
          "same_polarity": "食神",
          "different_polarity": "伤官"
        },
        "wealth": {
          "same_polarity": "偏财",
          "different_polarity": "正财"
        },
        "authority": {
          "same_polarity": "七杀",
          "different_polarity": "正官"
        },
        "resource": {
          "same_polarity": "偏印",
          "different_polarity": "正印"
        }
      },
      "scoring": "年干、月干、时干按 1.0；四支藏干按藏干加权记分"
    },
    "strength": {
      "components": {
        "same_score": "score[日主五行]",
        "resource_score": "score[生我五行]",
        "output_score": "score[我生五行]",
        "wealth_score": "score[我克五行]",
        "authority_score": "score[克我五行]"
      },
      "month_bonus": {
        "same": 1.5,
        "resource": 1.2,
        "output": -0.8,
        "wealth": -1.0,
        "authority": -1.2
      },
      "formula": {
        "support_total": "same_score + resource_score + max(month_bonus, 0)",
        "drain_total": "output_score + wealth_score + authority_score + max(-month_bonus, 0)",
        "strength_ratio": "support_total / (support_total + drain_total)"
      },
      "level_thresholds": {
        "强": "ratio >= 0.68",
        "偏强": "0.58 <= ratio < 0.68",
        "中和": "0.42 <= ratio < 0.58",
        "偏弱": "0.32 <= ratio < 0.42",
        "弱": "ratio < 0.32"
      }
    },
    "structure": {
      "support_ratio_base": "(same_score + resource_score) / base_total",
      "visible_support_count": "年干/月干/时干中，元素属于[同我,生我]的数量",
      "root_support_count": "四支中包含[同我,生我]藏干的支数",
      "judge": [
        "强 && support_ratio_base >= 0.70 && month_bonus > 0 && (output+wealth+authority) <= 2.0 -> 从格/从旺",
        "弱 && support_ratio_base <= 0.25 && month_bonus < 0 && visible_support_count == 0 && root_support_count == 0 -> 从格/从儿|从财|从官杀",
        "其他 -> 正格/扶抑正格"
      ]
    },
    "shensha": {
      "taohua": "按年支与日支查桃花，任一命中即算",
      "tianyi": "按日干查天乙贵人"
    },
    "dayun_liunian": {
      "direction_rule": "阳男阴女顺，阴男阳女逆",
      "start_rule": {
        "顺排": "出生时刻到下一个节的时间差",
        "逆排": "出生时刻到上一个节的时间差",
        "decimal_years": "delta_hours / 72"
      },
      "dayun_rule": "以月柱为基准，顺/逆移一个 60 甲子位为第一步大运，之后每 10 年移一位",
      "liunian_rule": "按立春切换年柱；若以流年标签输出，则年份 y 的流年柱直接按 ((y-4)%10, (y-4)%12) 计算"
    }
  },
