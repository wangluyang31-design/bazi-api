{
  "meta": {
    "name": "chenggu_analysis",
    "version": "1.0-standard-51qian",
    "selected_standard": {
      "label": "民间通行标准版（51档）",
      "reason": "年/月/日/时权重表闭合后，最小可得21钱（2两1钱），最大可得71钱（7两1钱）；适合作为统一可计算标准。",
      "not_included": [
        "附加72钱条目",
        "男女分版断语"
      ],
      "notes": [
        "年骨重以六十甲子作为查表键，不直接依赖网页里可能带误差的公历示例年份。",
        "内部统一用“钱”整数存储，展示时再格式化为“两/钱”，避免浮点误差。"
      ]
    },
    "input_schema": {
      "birth_datetime": "string",
      "timezone": "string (optional, default Asia/Shanghai)",
      "calendar_type": "gregorian|lunar (optional, default gregorian)",
      "gender": "optional, reserved for future male/female verse extension"
    },
    "decision_flow": [
      "解析出生时间",
      "必要时将公历转农历",
      "应用称骨边界规则（夜子时与闰月）",
      "查年/月/日/时骨重",
      "求和得到 total_qian",
      "匹配歌诀",
      "执行关键词+人工覆写的结构化标签提取",
      "生成事业/财运/婚姻/建议输出"
    ],
    "derived_features": [
      "year_ganzhi",
      "lunar_month",
      "lunar_day",
      "hour_branch",
      "year_weight_qian",
      "month_weight_qian",
      "day_weight_qian",
      "hour_weight_qian",
      "total_qian",
      "total_display",
      "grade",
      "trajectory_tags"
    ]
  },
